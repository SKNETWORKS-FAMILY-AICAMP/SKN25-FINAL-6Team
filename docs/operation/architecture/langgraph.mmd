APPROVAL_GATE["approval_gate_node<br/><br/>근거 문서 일치 여부<br/>Hallucination 여부<br/>정책 위반 여부<br/>욕설 / 유해 표현 여부"]

SAVE_SAFETY["save_safety_result_node<br/><br/>RDBMS · safety_results 저장"]

ROUTE_BY_APPROVAL{"route_by_approval"}

PUBLISH["publish_final_answer_node<br/><br/>최종 응답 게시<br/>QA_ticket.status = closed"]

HUMAN_REVIEW["human_review_node<br/><br/>운영자 검수<br/>답변 수정<br/>수동 지급<br/>환불 처리"]

ROUTE_BY_HUMAN{"route_by_human_decision"}

RETRY_ROUTING["retry_routing_node<br/><br/>reject 사유 저장<br/>기존 draft 폐기<br/>routing 재시도 플래그 설정<br/>retry_count 증가"]

EDIT_ANSWER["edit_answer_node<br/><br/>운영자 현장 수정<br/>edited_answer 저장"]

SAVE_FINAL_EDIT["save_final_edit_node<br/><br/>RDBMS · response_revision 저장<br/>수정 전/후 답변 기록"]

URGENT_ALERT["urgent_alert_node<br/><br/>긴급 알림 이메일 발송<br/>운영 담당자 / 관리자 알림"]

END((END))

START --> LOAD_TICKET
LOAD_TICKET --> QUERY_ROUTER
QUERY_ROUTER --> ROUTE_BY_QUERY

ROUTE_BY_QUERY -->|"payment"| PAYMENT_CONTEXT
ROUTE_BY_QUERY -->|"refund"| REFUND_CONTEXT
ROUTE_BY_QUERY -->|"item_delivery"| ITEM_CONTEXT
ROUTE_BY_QUERY -->|"gacha"| GACHA_CONTEXT
ROUTE_BY_QUERY -->|"policy"| POLICY_CONTEXT
ROUTE_BY_QUERY -->|"abuse"| ABUSE_CONTEXT
ROUTE_BY_QUERY -->|"outage"| OUTAGE_CONTEXT

PAYMENT_CONTEXT --> ANALYZE
REFUND_CONTEXT --> ANALYZE
ITEM_CONTEXT --> ANALYZE
GACHA_CONTEXT --> ANALYZE
POLICY_CONTEXT --> ANALYZE
ABUSE_CONTEXT --> ANALYZE
OUTAGE_CONTEXT --> ANALYZE

ANALYZE --> SAVE_ANALYSIS
SAVE_ANALYSIS --> ROUTE_BY_TARGET

ROUTE_BY_TARGET -->|"rag_reply"| RAG_RETRIEVE
ROUTE_BY_TARGET -->|"urgent_alert"| URGENT_DRAFT

RAG_RETRIEVE --> GENERATE_ANSWER
GENERATE_ANSWER --> SAVE_DRAFT
GENERATE_ANSWER --> SAVE_EVIDENCE

URGENT_DRAFT --> SAVE_DRAFT

SAVE_DRAFT --> APPROVAL_GATE
SAVE_EVIDENCE --> APPROVAL_GATE

APPROVAL_GATE --> SAVE_SAFETY
SAVE_SAFETY --> ROUTE_BY_APPROVAL

ROUTE_BY_APPROVAL -->|"approved"| PUBLISH
ROUTE_BY_APPROVAL -->|"human_review"| HUMAN_REVIEW
ROUTE_BY_APPROVAL -->|"urgent_alert"| URGENT_ALERT

HUMAN_REVIEW --> ROUTE_BY_HUMAN

ROUTE_BY_HUMAN -->|"approved"| PUBLISH
ROUTE_BY_HUMAN -->|"reject"| RETRY_ROUTING
ROUTE_BY_HUMAN -->|"edit"| EDIT_ANSWER

RETRY_ROUTING --> QUERY_ROUTER

EDIT_ANSWER --> SAVE_FINAL_EDIT
SAVE_FINAL_EDIT --> PUBLISH

PUBLISH --> END
URGENT_ALERT --> END

