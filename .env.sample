# External PostgreSQL connection string
DATABASE_URL=postgresql://USERNAME:PASSWORD@DB_HOST:5432/game_cs_demo

# LLM / AI provider
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4

# Optional retrieval configuration for operation STEP2
EMBEDDING_MODEL=openai:text-embedding-3-small
VECTOR_COLLECTION=game_cs_docs
RETRIEVAL_TOP_K=3
