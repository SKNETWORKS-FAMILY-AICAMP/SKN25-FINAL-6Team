APP_ENV=local

# External PostgreSQL connection string
DATABASE_URL=postgresql://USERNAME:PASSWORD@DB_HOST:5432/game_cs_demo

# LLM / AI provider
OPENAI_API_KEY=
OPENAI_MODEL=openai:gpt-5.4

# Optional retrieval configuration
EMBEDDING_MODEL=
VECTOR_COLLECTION=game_cs_docs

# Optional app settings
LOG_LEVEL=INFO
DEFAULT_TIMEZONE=Asia/Seoul
DEFAULT_TICKET_ID=1001
USE_SEED_PAYLOAD=true
