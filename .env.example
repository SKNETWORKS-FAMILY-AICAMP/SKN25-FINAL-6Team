# Tailscale IP or MagicDNS name for the external PostgreSQL/pgvector database.
# Do not use localhost here when the app runs inside Docker.
DB_HOST=100.x.y.z
DB_PORT=5432
DB_USER=
DB_NAME=
DB_PASSWORD=
DB_CONNECT_TIMEOUT=15

LLM_API_KEY=
LLM_MODEL=

CHATBOT_API_BASE_URL=http://chatbot-backend:8000
OPERATION_API_BASE_URL=http://operation-backend:8000
DASHBOARD_API_BASE_URL=http://dashboard-backend:8000

# Dashboard weekly report Slack delivery
# The API scheduler sends the weekly report every Monday at 09:00 Asia/Seoul
DASHBOARD_SLACK_BOT_TOKEN=
# Used by POST /reports/weekly/slack/now and scheduler default target channel
DASHBOARD_WEEKLY_REPORT_CHANNEL=#ops-dashboard
DASHBOARD_WEEKLY_REPORT_AUTOSTART=1

# LangSmith 트레이싱 설정
# LANGSMITH_API_KEY: smith.langchain.com 에서 발급
# LANGSMITH_PROJECT: 트레이스를 묶을 프로젝트 이름
# LANGCHAIN_TRACING_V2: true 로 설정하면 LangGraph 워크플로우가 자동으로 LangSmith에 기록됨
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=skn25-final-6team
LANGCHAIN_TRACING_V2=true
