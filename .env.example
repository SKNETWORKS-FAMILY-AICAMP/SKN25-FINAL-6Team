# LangSmith 트레이싱 설정
# LANGSMITH_API_KEY: smith.langchain.com 에서 발급
# LANGSMITH_PROJECT: 트레이스를 묶을 프로젝트 이름
# LANGCHAIN_TRACING_V2: true 로 설정하면 LangGraph 워크플로우가 자동으로 LangSmith에 기록됨
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=skn25-final-6team
LANGCHAIN_TRACING_V2=true
# LangSmith / LangChain tracing
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=game_cs_chatbot
LANGCHAIN_TRACING_V2=false
